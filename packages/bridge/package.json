{
  "name": "@postep/bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./platform/android/saf": {
      "import": "./src/platform/android/saf.ts"
    },
    "./lexical-harness": {
      "import": "./examples/lexical-harness.tsx"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "check": "tsc --noEmit",
    "dev:harness": "tsx examples/lexical-harness.tsx"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.6.2",
    "@types/node": "20.12.7",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "lexical": "0.45.0",
    "tsup": "7.2.0",
    "tsx": "4.15.7",
    "typescript": "5.6.3"
  }
}
