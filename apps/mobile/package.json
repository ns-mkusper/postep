{
  "name": "@postep/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:standalone:prebuild": "CI=1 expo prebuild --platform android --clean",
    "android:standalone:build": "cd android && ./gradlew assembleRelease",
    "android:standalone:install": "adb install -r android/app/build/outputs/apk/release/app-release.apk",
    "ios": "expo run:ios",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:ux": "tsx --test __tests__/*.test.ts",
    "test:storage": "tsx --test __tests__/safAgendaSources.test.ts __tests__/safRoamSources.test.ts --test-reporter=spec",
    "benchmark:ux": "UX_BENCH_RUNS=100 UX_BENCH_WARMUPS=10 tsx --test __tests__/editorFrontendBenchmarks.test.ts --test-reporter=spec",
    "benchmark:routes": "tsx --test __tests__/routeSwitchingPerformance.test.ts --test-reporter=spec",
    "e2e:web:build": "EXPO_PUBLIC_POSTEP_E2E=1 expo export --platform web --output-dir dist-e2e-web",
    "e2e:web": "playwright test e2e/web",
    "e2e:android:prebuild": "EXPO_PUBLIC_POSTEP_E2E=1 CI=1 expo prebuild --platform android --clean",
    "e2e:android:build": "cd android && ./gradlew assembleDebug",
    "e2e:android:install": "adb install -r -t -d -g android/app/build/outputs/apk/debug/app-debug.apk"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-router": "~3.5.24",
    "expo-status-bar": "~1.12.0",
    "expo-file-system": "~17.0.1",
    "expo-linking": "~6.3.1",
    "expo-secure-store": "~13.0.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.3",
    "react-native-web": "~0.19.10",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "~4.10.1",
    "react-native-screens": "~3.31.1",
    "@react-navigation/drawer": "^6.7.2",
    "@tanstack/react-query": "5.59.20",
    "lexical": "0.45.0",
    "zustand": "4.5.4",
    "web-streams-polyfill": "3.3.3"
  },
  "devDependencies": {
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "typescript": "5.6.3",
    "tsx": "4.15.7",
    "@types/node": "20.12.7",
    "@playwright/test": "1.44.1",
    "pixelmatch": "5.3.0",
    "pngjs": "7.0.0",
    "serve": "14.2.3"
  }
}
